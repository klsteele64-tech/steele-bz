{
  "name": "steele-bz",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "site",
    "apps/*"
  ],
  "dependencies": {
    "hono": "^4.7.4"
  },
  "scripts": {
    "dev": "npm run dev --workspace=site",
    "dev:apps": "VITE_BASE=/apps/burger-buds/ npm run dev --workspace=burger-buds",
    "bundle:training-api": "node scripts/bundle-training-api.mjs",
    "build": "node scripts/bundle-training-api.mjs && node scripts/build-all.mjs",
    "build:site": "npm run build --workspace=site",
    "preview": "npx wrangler pages dev dist --port 8788"
  },
  "devDependencies": {
    "wrangler": "^4.14.0"
  }
}

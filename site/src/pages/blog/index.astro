---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";

let posts: Awaited<ReturnType<typeof getCollection<"blog">>> = [];
try {
  posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
} catch {
  posts = [];
}
---

<BaseLayout title="Blog" description="Writing and notes from Kasey Steele.">
  <h1>Blog</h1>
  {posts.length === 0 ? (
    <div class="empty-state">
      <p>Blog coming soon. The content collection is ready — add markdown files under <code>site/src/content/blog/</code> to publish posts.</p>
    </div>
  ) : (
    <div class="card-grid">
      {posts.map((post) => (
        <Card
          title={post.data.title}
          description={post.data.description}
          href={`/blog/${post.slug}/`}
          meta={post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        />
      ))}
    </div>
  )}
</BaseLayout>

<style>
  code {
    font-size: 0.9em;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }
</style>
